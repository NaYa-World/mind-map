# Naya MindMap Template Environment Configurations
# Copy this file to .env and fill in with your credentials

# Sentry DSN for error reporting
VITE_SENTRY_DSN=

# Google Drive Client ID for GIS authorization
VITE_GOOGLE_CLIENT_ID=

# Stripe Payment Link for Premium upgrades
VITE_STRIPE_PAYMENT_LINK=

# PostHog API Key for usage metrics
VITE_POSTHOG_API_KEY=

# License Key required to authorize application execution
VITE_LICENSE_KEY=

# Build target ('web' or 'mobile'). If 'mobile', premium checks are bypassed.
VITE_BUILD_TARGET=web

